# Day 09 Lab — Environment Variables
# Copy file này thành .env và điền giá trị thật:
#   cp .env.example .env

# ─── Chọn 1 trong 3 LLM provider: openai | gemini | deepseek ───

# Đặt LLM provider (default: openai)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Configuration: OpenAI
# Lấy API key từ: https://platform.openai.com/api-keys
# Uncomment nếu dùng OpenAI (LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...your-openai-key-here...

# Configuration: Google Gemini
# Lấy API key từ: https://ai.google.dev
# Uncomment nếu dùng Gemini (LLM_PROVIDER=gemini)
# GOOGLE_API_KEY=AIzaSy...your-gemini-key-here...
# GEMINI_MODEL=gemini-1.5-flash

# Configuration: Deepseek (OpenAI-compatible API)
# Lấy API key từ: https://platform.deepseek.com
# Uncomment nếu dùng Deepseek (LLM_PROVIDER=deepseek)
# DEEPSEEK_API_KEY=sk-...your-deepseek-key-here...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# ─── Cấu hình ChromaDB ───
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=day09_docs

# ─── Cấu hình Retrieval ───
RETRIEVAL_TOP_K=3

# ─── Cấu hình MCP (Sprint 3 - optional) ───
# MCP_SERVER_URL=http://localhost:8080
# MCP_SERVER_MODE=mock   # hoặc "http" nếu dùng real HTTP server

# ─── Cấu hình Trace ───
TRACE_OUTPUT_DIR=./artifacts/traces
