# Day 09 Lab — Environment Variables
#
# Cách nhanh (dùng chung key với Day 8):
#   Copy day08/lab/.env vào day09/lab/.env
#   (PowerShell: Copy-Item ..\day08\lab\.env .env   khi đang ở day09/lab)
#
# Hoặc copy file này thành .env và điền key:
#   cp .env.example .env

# ─── Chọn 1 trong 2 LLM provider ───

# Option A: OpenAI (GPT-4o-mini hoặc GPT-4o)
OPENAI_API_KEY=sk-...your-key-here...

# Option B: Google Gemini
# GOOGLE_API_KEY=AI...your-key-here...

# ─── Cấu hình ChromaDB ───
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=day09_docs

# ─── Cấu hình Retrieval ───
RETRIEVAL_TOP_K=3
# openai | local | auto (default: local to match build_index.py all-MiniLM-L6-v2)
EMBEDDING_PROVIDER=local
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Cấu hình MCP (Sprint 3 - optional) ───
# MCP_SERVER_URL=http://localhost:8080
# MCP_SERVER_MODE=mock   # hoặc "http" nếu dùng real HTTP server

# ─── Cấu hình Trace ───
TRACE_OUTPUT_DIR=./artifacts/traces
