# Day 08 Lab — RAG Pipeline
# Copy file này thành .env và điền API key

# === LLM Provider ===
# Chọn "openai" hoặc "gemini"
LLM_PROVIDER=openai

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Google Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=...

# Model mặc định
LLM_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-1.5-flash

# === Eval / LLM-as-Judge ===
# Bật/tắt chấm tự động bằng LLM trong eval.py
USE_LLM_JUDGE=true

# Mặc định judge dùng cùng provider/model với generation nếu không set riêng
# JUDGE_PROVIDER=openai
# JUDGE_MODEL=gpt-4o-mini
# JUDGE_TIMEOUT_SECONDS=60
# JUDGE_CONTEXT_CHAR_LIMIT=5000

# === Embedding ===
# Chọn "openai" hoặc "local" (sentence-transformers)
EMBEDDING_PROVIDER=openai

# Model sentence-transformers nếu dùng local embedding
# LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
