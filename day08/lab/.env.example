# Day 08 Lab — RAG Pipeline
# Copy file này thành .env và điền API key

# === LLM Provider ===
# Chọn "openai" hoặc "gemini"
LLM_PROVIDER=openai

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Google Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=...

# Model mặc định
LLM_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-1.5-flash

# === Embedding ===
# Chọn "openai" hoặc "local" (sentence-transformers)
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Model sentence-transformers nếu dùng local embedding
# LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# === Retrieval tuning (rag_answer.py — có thể bỏ trống để dùng mặc định) ===
# TOP_K_SEARCH=12
# TOP_K_SELECT=4
# RRF_K=60

# === LLM-as-Judge (eval.py) ===
# USE_LLM_JUDGE=1

# === Telemetry / chi phí ước lượng (run_telemetry.py → logs/runs.jsonl) ===
# USD per 1M tokens — cập nhật theo https://openai.com/api/pricing
# LAB_PRICE_CHAT_INPUT_PER_M=0.15
# LAB_PRICE_CHAT_OUTPUT_PER_M=0.60
# LAB_PRICE_EMBEDDING_PER_M=0.02

# === FastAPI (api_server.py) ===
# RAG_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# LOG_LEVEL=INFO
