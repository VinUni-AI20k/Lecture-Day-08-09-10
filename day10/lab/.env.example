# Day 10 Lab environment

# ChromaDB
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=day10_kb

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2
# If set, OpenAI embedding is used instead of local model.
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=
# OPENAI_API_BASE=

# Freshness SLA
FRESHNESS_SLA_HOURS=24
INGEST_FRESHNESS_SLA_HOURS=24

# Optional overrides (defaults are loaded from contracts/data_contract.yaml)
# HR_LEAVE_MIN_EFFECTIVE_DATE=2026-01-01
# REFUND_WINDOW_DAYS=7

# Optional for custom extensions
# OPENAI_API_KEY=
